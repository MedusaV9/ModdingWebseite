{
	"format_version": "1.8.0",
	"animations": {
		"animation.shadow_bolt.idle": {
			"loop": true,
			"animation_length": 1.0,
			"bones": {
				"root": {
					"rotation": [0, "query.anim_time * 360", 0]
				},
				"spikes": {
					"rotation": ["query.anim_time * 360", 0, "query.anim_time * -360"]
				},
				"glow_core": {
					"position": [0, "math.sin(query.anim_time * 720) * 0.3", 0],
					"rotation": [0, "query.anim_time * -360", 0]
				}
			}
		}
	}
}
